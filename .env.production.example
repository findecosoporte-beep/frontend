# Producción (Railway)
# VITE_* se inyectan en el BUILD. En Railway → Variables del servicio front:
#
# Opción A — referencia al servicio API (recomendado):
# VITE_API_BASE_URL=https://${{NOMBRE_SERVICIO_API.RAILWAY_PUBLIC_DOMAIN}}/api/v1
#
# Opción B — URL fija tras generar dominio del API:
# VITE_API_BASE_URL=https://backendfindeco2-production.up.railway.app/api/v1

VITE_API_BASE_URL=https://web-production-93580.up.railway.app/api/v1
